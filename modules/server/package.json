{
  "name": "@inscription/server",
  "main": "src/server.ts",
  "scripts": {
    "dev": "tsc-watch -b --onSuccess \"yarn serve\"",
    "clean": "rimraf ./dist",
    "serve": "tsc-alias && dotenv -e .env.development -- node dist/server.js"
  },
  "dependencies": {
    "@inscription/shared": "workspace:*",
    "better-sqlite3": "^11.0.0",
    "cors": "^2.8.5",
    "env-var": "^7.5.0",
    "express": "^4.19.2",
    "luxon": "^3.4.4",
    "short-unique-id": "^5.2.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.4.0",
    "@types/better-sqlite3": "^7.6.10",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/luxon": "^3.4.2",
    "@types/node": "^20.14.2",
    "dotenv-cli": "^7.4.2",
    "eslint-config-prettier": "^9.1.0",
    "prettier": "^3.3.2",
    "rimraf": "^5.0.7",
    "tsc-alias": "^1.8.10",
    "tsc-watch": "^6.2.0",
    "typescript": "^5.4.5",
    "typescript-eslint": "^7.13.0"
