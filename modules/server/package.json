{
  "name": "@inscription/server",
  "main": "src/server.ts",
  "scripts": {
    "dev": "tsc-watch -b --onSuccess \"yarn serve\"",
    "clean": "rimraf ./dist",
    "serve": "tsc-alias && dotenv -e .env.development -- node dist/server.js"
  },
  "dependencies": {
    "@inscription/shared": "workspace:*",
    "env-var": "^7.5.0",
    "express": "^4.19.2"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.12.12",
    "dotenv-cli": "^7.4.2",
    "prettier": "^3.2.5",
    "rimraf": "^5.0.7",
    "tsc-alias": "^1.8.10",
    "tsc-watch": "^6.2.0",
    "typescript": "^5.4.5"
  }
}
