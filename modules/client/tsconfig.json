{
  "compilerOptions": {
    "target": "ES2020",
    "allowJs": true,
    "jsx": "react",
    "moduleResolution": "Bundler",
    "strict": true,
    "esModuleInterop": true,

    "baseUrl": ".",
    "paths": {
      "~/*": ["src/*"],
      "Utils/*": ["src/utils/*"]
    }
  },
  "include": ["src/**/*"]
}
